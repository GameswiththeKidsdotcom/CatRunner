# C10 — Fastlane for CatRunner. Manual TestFlight by default; automation when secrets are set.

default_platform(:ios)

platform :ios do
  desc "Build and optionally upload to TestFlight (automation when App Store Connect API key is set)"
  lane :beta do
    # Build IPA for App Store distribution (same as deploy.yml archive intent)
    build_app(
      scheme: "CatRunner",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "CatRunner.ipa"
    )

    # Upload to TestFlight only when App Store Connect API key is available.
    # Required env (e.g. GitHub secrets): APP_STORE_CONNECT_KEY_ID, APP_STORE_CONNECT_ISSUER_ID,
    # and either APP_STORE_CONNECT_KEY_PATH (path to .p8 file) or APP_STORE_CONNECT_KEY_CONTENT (raw .p8 content).
    key_id = ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_path = ENV["APP_STORE_CONNECT_KEY_PATH"]
    key_content = ENV["APP_STORE_CONNECT_KEY_CONTENT"]

    if key_id && issuer_id && (key_path || key_content)
      api_key_params = { key_id: key_id, issuer_id: issuer_id }
      if key_content.to_s.length > 0
        api_key_params[:key_content] = key_content
      elsif key_path && File.exist?(key_path)
        api_key_params[:key_filepath] = key_path
      else
        UI.user_error!("APP_STORE_CONNECT_KEY_PATH must point to a .p8 file, or APP_STORE_CONNECT_KEY_CONTENT must be set.")
      end
      api_key = app_store_connect_api_key(api_key_params)
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true
      )
      UI.success("Uploaded to TestFlight. Check App Store Connect for processing.")
    else
      UI.important("App Store Connect API key not set. IPA built at ios/build/CatRunner.ipa — upload manually (Xcode Organizer or altool).")
      UI.important("To enable automation, set: APP_STORE_CONNECT_KEY_ID, APP_STORE_CONNECT_ISSUER_ID, and APP_STORE_CONNECT_KEY_PATH or APP_STORE_CONNECT_KEY_CONTENT. See ios/fastlane/README.md.")
    end
  end
end
