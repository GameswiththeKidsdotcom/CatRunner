{
  "$schema": "../schema.json",
  "engine": {
    "lanes": 5,
    "playerStartLane": 2,
    "segmentDurationSeconds": { "min": 2.0, "max": 3.0 },
    "jumpDurationSeconds": 0.4,
    "slideDurationSeconds": 0.5,
    "baseSpeed": 1.0,
    "deterministicPhysics": true
  },
  "obstacles": {
    "types": [
      { "id": "passable", "laneSpan": [1, 2] },
      { "id": "instantFail", "laneSpan": [1, 3] },
      { "id": "slowdown", "laneSpan": [1, 2] }
    ],
    "segmentDurationSeconds": 2.5,
    "clusterConfig": {
      "enabled": false,
      "minGroupSize": 2,
      "maxGroupSize": 3,
      "layout": "linear"
    }
  },
  "powerUps": {
    "types": ["speedBoost", "shield"],
    "maxActive": 1,
    "spawnProbability": 0.15,
    "placementRule": "freeLaneOnly"
  },
  "difficultyScaling": {
    "speedIncrementPerSegment": 0.02,
    "multiLaneProbabilityIncrement": 0.01,
    "instantFailProbabilityIncrement": 0.005,
    "segmentsPerStep": 5
  },
  "monetization": {
    "reviveIAPProductId": null,
    "rewardedAdPlacementId": null
  }
}
